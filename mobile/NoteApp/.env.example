# Backend API (dùng IP máy tính khi test trên điện thoại thật)
EXPO_PUBLIC_API_URL=http://192.168.1.224:5000/api

# Firebase (Firebase Console > Project settings)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google OAuth — PHẢI cùng Firebase project (note-f6b47 / 862670529475)
# Lấy Web client ID từ Firebase Console → Authentication → Google
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# Expo Go iOS: Bundle ID = host.exp.Exponent
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# Expo Go Android: Package = host.exp.exponent, SHA-1 required
# MUST enable "Custom URI scheme" on Android OAuth client in Google Cloud
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
